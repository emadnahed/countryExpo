{
  "name": "country-explorer",
  "version": "1.0.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild --clean",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "test:ci": "jest --ci",
    "test:all": "jest --ci && detox test --configuration ios.sim.debug",
    "e2e:build": "detox build --configuration ios.sim.debug",
    "e2e:test": "detox test --configuration ios.sim.debug",
    "e2e:test:ci": "detox test --configuration ios.sim.debug --headless --record-logs all",
    "e2e:android:build": "detox build --configuration android.emu.debug",
    "e2e:android:test": "detox test --configuration android.emu.debug --headless --record-logs all",
    "e2e:android:ci": "detox test --configuration android.ci.debug --headless --record-logs all",
    "lint": "expo lint",
    "fresh-build-physical-devices": "bash scripts/fresh-build-physical-devices.sh",
    "clean": "rm -rf node_modules .expo ios android && rm -rf ~/Library/Developer/Xcode/DerivedData/*",
    "clean:ios": "rm -rf ios && rm -rf ~/Library/Developer/Xcode/DerivedData/*",
    "clean:android": "rm -rf android",
    "fresh-install": "npm run clean && npm install",
    "setup:ios": "npm run clean:ios && npm install && npx expo prebuild --clean --platform ios",
    "setup:ios:device": "npm run setup:ios && npx expo run:ios --device",
    "setup:android": "npm run clean:android && npm install && npx expo prebuild --clean --platform android && cd android && ./gradlew clean && cd ..",
    "setup:android:device": "npm run setup:android && npx expo run:android --device",
    "ios:prebuild": "npx expo prebuild --platform ios --clean",
    "ios:archive": "cd ios && xcodebuild -workspace Paymadi.xcworkspace -scheme Paymadi -configuration Release -archivePath ./build/Paymadi.xcarchive archive",
    "ios:export": "cd ios && xcodebuild -exportArchive -archivePath ./build/Paymadi.xcarchive -exportOptionsPlist ./ExportOptions.plist -exportPath ./build/export -allowProvisioningUpdates",
    "ios:validate": "cd ios && xcodebuild -exportArchive -archivePath ./build/Paymadi.xcarchive -exportOptionsPlist ./ExportOptions.plist -exportPath ./build/export -allowProvisioningUpdates 2>&1 | grep -i 'error\\|warning\\|succeeded' || true",
    "ios:increment-build": "node scripts/increment-build.js ios",
    "ios:testflight": "npm run ios:increment-build && npm run ios:prebuild && npm run ios:archive && npm run ios:export",
    "ios:testflight:quick": "npm run ios:archive && npm run ios:export",
    "android:prebuild": "npx expo prebuild --platform android --clean",
    "android:bundle": "cd android && ./gradlew bundleRelease",
    "android:increment-build": "node scripts/increment-build.js android",
    "android:playstore": "npm run android:increment-build && npm run android:prebuild && npm run android:bundle && echo '✅ AAB ready at: android/app/build/outputs/bundle/release/app-release.aab'",
    "android:playstore:quick": "npm run android:bundle && echo '✅ AAB ready at: android/app/build/outputs/bundle/release/app-release.aab'"
  },
  "dependencies": {
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@reduxjs/toolkit": "^2.11.2",
    "axios": "^1.13.6",
    "expo": "~55.0.5",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "react": "19.2.4",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-mmkv": "^4.2.0",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-webview": "13.16.0",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.2",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "detox": "^20.47.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.9",
    "react-test-renderer": "19.2.4",
    "ts-jest": "^29.4.6",
    "typescript": "~5.9.2"
  },
  "jest": {
    "preset": "jest-expo",
    "testPathIgnorePatterns": ["/node_modules/", "/e2e/"],
    "moduleNameMapper": {
      "^react-native-reanimated$": "<rootDir>/__mocks__/react-native-reanimated.js",
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|react-navigation|@react-navigation/.*|react-native-mmkv|react-native-webview|@reduxjs|immer|react-redux)"
    ]
  }
}
